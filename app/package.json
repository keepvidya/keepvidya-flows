{
  "name": "keepvidya-flows-desktop",
  "productName": "Keepvidya Flows",
  "version": "0.1.1",
  "description": "Keepvidya Flows — local-first AI Flow apps. Own your intelligence.",
  "homepage": "https://keepvidya.com/products/flows",
  "author": {
    "name": "Gunjan Tailor",
    "email": "tailorgunjan89@gmail.com"
  },
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.keepvidya.flows",
    "productName": "Keepvidya Flows",
    "copyright": "Copyright © 2026 Keepvidya",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "keepvidya",
      "repo": "keepvidya-flows",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "Keepvidya-Flows-Setup-${version}.exe",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "Keepvidya Flows",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "assets/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "Keepvidya-Flows-${version}.dmg",
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Office",
      "description": "Local-first AI Flow apps",
      "artifactName": "Keepvidya-Flows-${version}.AppImage"
    }
  }
}
